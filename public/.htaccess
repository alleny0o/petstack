<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block directory listing for folders with no index file.
Options -Indexes

# Suppress the Apache version/OS string from error pages and the
# Server response header. Requires AllowOverride to permit core
# directives here (AllowOverride All, or FileInfo at minimum) — if the
# RHEL vhost restricts AllowOverride, set this in the server/vhost
# config instead (ServerTokens also lives there, not .htaccess).
ServerSignature Off

# Route missing pages to the on-brand 404 instead of Apache's default.
ErrorDocument 404 /404.php


# ------------- Remove the .php extensions (On MAMP) -------------

# RewriteEngine On

# # 1. Remove .php extension from URLs internally
# # If a user requests /catalog, check if /catalog.php exists as a file
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteCond %{REQUEST_FILENAME}\.php -f
# RewriteRule ^([^\.]+)$ $1.php [NC,L]

# # 2. (Optional) Redirect visitors typing .php to the clean URL
# # e.g., redirect /catalog.php -> /catalog
# RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.php\ HTTP/
# RewriteRule ^([^\.]+)\.php$ /$1 [R=301,L]